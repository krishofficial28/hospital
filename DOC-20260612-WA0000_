function renderDatabase(el){
  el.innerHTML=`
    <h2>🗄️ Database Schema (MySQL)</h2>
    <p class="text-muted mb-1" style="font-size:.85rem">Complete SQL schema for production MySQL setup.</p>
    <div class="card" style="background:var(--input)">
      <pre style="font-size:.75rem;color:#16261E;overflow-x:auto;white-space:pre-wrap;line-height:1.6">${SQL_SCHEMA}</pre>
    </div>
    <button class="btn btn-outline btn-sm mt-1" onclick="downloadSQL()">📥 Download SQL Schema</button>
    <hr/>
    <h3>📊 ERD Overview</h3>
    <div class="card">
      <pre style="font-size:.82rem;color:var(--muted);line-height:1.8">
  doctors ──┐
            ├──→ admissions ←── beds
  patients ─┘         ↑
       ↓               └── (room link)
  predictions (disease AI results)
  users (auth/login)</pre>
    </div>
  `;
}

const SQL_SCHEMA = `CREATE DATABASE IF NOT EXISTS hospital_db;
USE hospital_db;

CREATE TABLE IF NOT EXISTS doctors (
    doctor_id   INT AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(100) NOT NULL,
    speciality  VARCHAR(100),
    phone       VARCHAR(15),
    email       VARCHAR(100) UNIQUE,
    created_at  DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS patients (
    patient_id    VARCHAR(10) PRIMARY KEY,
    name          VARCHAR(100) NOT NULL,
    age           INT,
    gender        ENUM('Male','Female','Other'),
    blood_group   VARCHAR(5),
    diagnosis     VARCHAR(200),
    bed_type      ENUM('ICU','Emergency','General'),
    admission_date DATETIME,
    status        ENUM('Admitted','Discharged','Critical','Stable') DEFAULT 'Admitted',
    doctor_id     INT,
    risk_level    ENUM('Low','Medium','High') DEFAULT 'Low',
    created_at    DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (doctor_id) REFERENCES doctors(doctor_id)
);

CREATE TABLE IF NOT EXISTS predictions (
    pred_id     VARCHAR(15) PRIMARY KEY,
    patient_id  VARCHAR(10),
    disease     ENUM('Diabetes','Heart Disease','Kidney Disease'),
    model_used  VARCHAR(50),
    prediction  ENUM('Positive','Negative'),
    probability DECIMAL(6,4),
    timestamp   DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (patient_id) REFERENCES patients(patient_id)
);

CREATE TABLE IF NOT EXISTS users (
    user_id    INT AUTO_INCREMENT PRIMARY KEY,
    username   VARCHAR(50) UNIQUE NOT NULL,
    password   VARCHAR(64) NOT NULL,
    role       ENUM('admin','doctor','nurse') DEFAULT 'nurse',
    full_name  VARCHAR(100),
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

INSERT IGNORE INTO users (username, password, role, full_name) VALUES
  ('arjun', SHA2('670798', 256),    'doctor', 'Dr. Arjun'),
  ('admin', SHA2('admin1234', 256), 'admin',  'Dr. Admin'),
  ('nurse', SHA2('nurse123', 256),  'nurse',  'Nurse Priya');`;

function downloadSQL(){
  const a = document.createElement('a');
  a.href = 'data:text/plain;charset=utf-8,'+encodeURIComponent(SQL_SCHEMA);
  a.download = 'hospital_schema.sql';
  a.click();
}
</script>
