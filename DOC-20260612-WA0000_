        scales:{x:{stacked:true,ticks:{color:'#7C9286'}},y:{stacked:true,ticks:{color:'#7C9286'},grid:{color:'#DFEEE6'}}},
        plugins:{legend:{labels:{color:'#16261E',font:{size:11}}}}}
    });
  },50);
}

// ═══════════════════════════════════════
// PANE: ANALYTICS
// ═══════════════════════════════════════
function renderAnalytics(el){
  const ages = state.patients.map(p=>parseInt(p.age)).filter(Boolean);
  const ageGroups={'0-20':0,'21-40':0,'41-60':0,'61-80':0,'81+':0};
  ages.forEach(a=>{
    if(a<=20) ageGroups['0-20']++;
    else if(a<=40) ageGroups['21-40']++;
    else if(a<=60) ageGroups['41-60']++;
    else if(a<=80) ageGroups['61-80']++;
    else ageGroups['81+']++;
  });
  const docCount={};
  state.patients.forEach(p=>{ if(p.doctor) docCount[p.doctor]=(docCount[p.doctor]||0)+1; });
  const disCount={};
  state.predictions.forEach(p=>{ if(p.disease) disCount[p.disease]=(disCount[p.disease]||0)+1; });
  const posNeg={Positive:0,Negative:0};
  state.predictions.forEach(p=>{ if(p.label) posNeg[p.label]++; });

  el.innerHTML=`
    <h2>📈 Hospital Analytics</h2>
    ${state.patients.length===0?'<div class="alert-info">No patient data yet. Admit patients to see analytics.</div>':''}
    <div class="g2">
      <div class="card">
        <h3>Age Distribution</h3>
        <div style="position:relative;height:220px"><canvas id="ageChart" role="img" aria-label="Age distribution bar chart">${Object.entries(ageGroups).map(([k,v])=>k+': '+v).join(', ')}</canvas></div>
      </div>
      <div class="card">
        <h3>Doctor Workload</h3>
        <div style="position:relative;height:220px"><canvas id="docChart" role="img" aria-label="Doctor patient load chart">${Object.entries(docCount).map(([k,v])=>k+': '+v).join(', ')||'No data'}</canvas></div>
      </div>
    </div>
    ${state.predictions.length?`
    <hr/>
    <h3>🔬 Prediction Analytics</h3>
    <div class="g2">
      <div class="card">
        <h3>Predictions by Disease</h3>
        <div style="position:relative;height:220px"><canvas id="disChart" role="img" aria-label="Predictions by disease chart">${Object.entries(disCount).map(([k,v])=>k+': '+v).join(', ')}</canvas></div>
      </div>
      <div class="card">
        <h3>Positive vs Negative</h3>
        <div style="position:relative;height:220px"><canvas id="pnChart" role="img" aria-label="Positive vs negative outcomes chart">Positive: ${posNeg.Positive}, Negative: ${posNeg.Negative}</canvas></div>
      </div>
    </div>`:''}
  `;
  setTimeout(()=>{
    destroyChart('ageChart');
    state.charts['ageChart'] = new Chart(document.getElementById('ageChart'),{
      type:'bar',data:{labels:Object.keys(ageGroups),datasets:[{data:Object.values(ageGroups),backgroundColor:'#1B7F4C'}]},
      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
        scales:{x:{ticks:{color:'#7C9286'}},y:{ticks:{color:'#7C9286'},grid:{color:'#DFEEE6'}}}}
    });
    destroyChart('docChart');
    if(Object.keys(docCount).length){
      state.charts['docChart'] = new Chart(document.getElementById('docChart'),{
        type:'bar',data:{labels:Object.keys(docCount),datasets:[{data:Object.values(docCount),backgroundColor:'#43C59E'}]},
        options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
          scales:{x:{ticks:{color:'#7C9286',maxRotation:30}},y:{ticks:{color:'#7C9286'},grid:{color:'#DFEEE6'}}}}
      });
    }
    if(state.predictions.length){
      destroyChart('disChart');
      state.charts['disChart'] = new Chart(document.getElementById('disChart'),{
        type:'bar',data:{labels:Object.keys(disCount),datasets:[{data:Object.values(disCount),backgroundColor:['#1B7F4C','#D6473E','#54B488']}]},
        options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
          scales:{x:{ticks:{color:'#7C9286'}},y:{ticks:{color:'#7C9286'},grid:{color:'#DFEEE6'}}}}
      });
      destroyChart('pnChart');
      state.charts['pnChart'] = new Chart(document.getElementById('pnChart'),{
        type:'doughnut',
        data:{labels:['Positive','Negative'],datasets:[{data:[posNeg.Positive,posNeg.Negative],backgroundColor:['#D6473E','#54B488'],borderColor:'#FFFFFF',borderWidth:2}]},
        options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#16261E'}}}}
      });
    }
  },50);
}

// ═══════════════════════════════════════
// PANE: HISTORY
// ═══════════════════════════════════════
function renderHistory(el){
  el.innerHTML=`
    <h2>📋 Prediction History</h2>
    ${state.predictions.length===0?'<div class="alert-info">No predictions yet. Run a prediction in the Prediction tab.</div>':''}
    ${state.predictions.length?`
    <div class="text-muted mb-05" style="font-size:.82rem"><strong>${state.predictions.length}</strong> predictions recorded</div>
    <div class="tbl-wrap">
      <table class="tbl">
        <thead><tr><th>ID</th><th>Patient</th><th>Disease</th><th>Result</th><th>Confidence</th><th>Time</th></tr></thead>
        <tbody>
          ${[...state.predictions].reverse().map(p=>{
            const prob = parseFloat(p.prob);
            const color = prob>0.65?'var(--danger)':prob>0.35?'var(--warn)':'var(--accent2)';
            return `<tr>
              <td class="text-accent">${p.id}</td>
              <td>${p.patientId}</td>
              <td>${p.disease}</td>
              <td><span class="chip ${p.label==='Positive'?'chip-high':'chip-low'}">${p.label}</span></td>
              <td style="color:${color};font-weight:700">${(prob*100).toFixed(1)}%</td>
              <td class="text-muted">${p.timestamp}</td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>
    <button class="btn btn-outline btn-sm mt-1" onclick="exportCSV()">📥 Export CSV</button>
    `:''}
  `;
}

function exportCSV(){
  const rows = [['ID','Patient','Disease','Result','Confidence','Time']];
  state.predictions.forEach(p=>rows.push([p.id,p.patientId,p.disease,p.label,(parseFloat(p.prob)*100).toFixed(1)+'%',p.timestamp]));
  const csv = rows.map(r=>r.join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download = 'predictions_export.csv';
  a.click();
  toast('CSV exported','success');
}

function exportPatientsCSV(){
  const rows = [['ID','Name','Age','Gender','Blood Group','Diagnosis','Bed','Status','Risk','Doctor','Admission Date']];
  state.patients.forEach(p=>rows.push([p.id,p.name,p.age,p.gender,p.bloodGroup||'',p.diagnosis||'',p.bedType,p.status,p.risk,p.doctor,p.admissionDate||p.createdAt||'']));
  const csv = rows.map(r=>r.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download = 'patients_export.csv';
  a.click();
  toast('Patient records exported','success');
}

// ═══════════════════════════════════════
// PANE: CHATBOT (AI powered)
// ═══════════════════════════════════════
const KB = {
  diabetes:'Diabetes is a chronic condition affecting blood sugar. Key risk factors: obesity, family history, inactivity. Management: medication (metformin), diet control, exercise, and blood sugar monitoring.',
  heart:'Heart disease includes CAD, arrhythmia, and heart failure. Risk factors: high BP, high cholesterol, smoking. Prevention: healthy diet, exercise, no smoking.',
  kidney:'Kidney disease affects waste filtration. Causes: diabetes, hypertension. Symptoms: swelling, fatigue, reduced urine output. Early detection via creatinine & eGFR tests.',
  symptoms:'⚠️ Common warning signs: unexplained fatigue, chest pain, frequent urination, limb swelling, shortness of breath. Consult a doctor immediately.',
  bed:'Bed availability is updated in real-time. ICU: critical. Emergency: urgent. General: routine. Check the Beds tab for live counts.',
  diet:'🥗 Healthy diet: reduce sugar & sodium, increase fruits & vegetables, stay hydrated (≥8 glasses/day), limit processed foods.',
  emergency:'🚨 For emergencies call 104 (National Medical Helpline). Go to Emergency immediately for chest pain, difficulty breathing, or stroke symptoms.',
  'blood pressure':'Normal BP: 120/80 mmHg. High BP (>140/90) increases risk of heart disease and stroke. Monitor regularly.',
  bmi:'BMI < 18.5: Underweight | 18.5–24.9: Normal | 25–29.9: Overweight | ≥30: Obese.',
  hello:"Hello! 👋 I'm MedBot — your AI assistant. Ask about diseases, symptoms, diet, or bed availability.",
};

function renderChatbot(el){
  el.innerHTML=`
    <h2>🤖 MedBot — AI Medical Assistant</h2>
    <div class="card">
      <div class="chat-box" id="chat-msgs">
        ${state.chatHistory.map(m=>`<div class="${m.role==='user'?'chat-user':'chat-bot'}">${m.role==='user'?'🧑':'🤖'} ${m.msg}</div>`).join('')}
      </div>
      <div style="display:flex;gap:.6rem">
        <input id="chat-in" placeholder="Ask MedBot anything…" style="flex:1" 
          onkeydown="if(event.key==='Enter')sendChat()"/>
        <button class="btn" style="width:90px" onclick="sendChat()">Send ➤</button>
      </div>
      <div style="margin-top:.6rem;text-align:right">
        <button class="btn btn-outline btn-sm" onclick="clearChat()">🗑️ Clear Chat</button>
      </div>
    </div>
    <div class="card mt-1">
      <div class="text-muted" style="font-size:.82rem">💡 Try asking: <em>What are symptoms of diabetes? | How to reduce heart risk? | Are beds available? | What is kidney disease?</em></div>
    </div>
  `;
  scrollChat();
}

function scrollChat(){
  const box = document.getElementById('chat-msgs');
  if(box) box.scrollTop = box.scrollHeight;
}

async function sendChat(){
  const inp = document.getElementById('chat-in');
  const msg = inp.value.trim();
  if(!msg) return;
  inp.value='';

  state.chatHistory.push({role:'user',msg});
  renderChatbot(document.getElementById('pane-chatbot'));

  // Quick KB lookup
  const text = msg.toLowerCase();
  let reply = null;
  for(const [k,r] of Object.entries(KB)){
    if(text.includes(k)){ reply=r; break; }
  }

  if(!reply){
    // Show typing indicator while AI responds
    const box = document.getElementById('chat-msgs');
    if(box){
      const typingEl = document.createElement('div');
      typingEl.className='chat-bot';
      typingEl.id='typing-indicator';
      typingEl.innerHTML='🤖 <span class="spinner" style="width:12px;height:12px;vertical-align:middle"></span> MedBot is typing…';
      box.appendChild(typingEl);
      box.scrollTop = box.scrollHeight;
    }
    // Try Anthropic API
    try {
      const resp = await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          model:'claude-sonnet-4-20250514',
          max_tokens:250,
          messages:[
            {role:'user',content:`You are MedBot, a helpful hospital AI assistant. Answer briefly and clearly in 2-3 sentences. User question: ${msg}`}
          ]
        })
      });
      const data = await resp.json();
      reply = data.content.map(c=>c.text||'').join('').trim();
    } catch(e) {
      reply = "I'm not sure about that. Please consult our medical staff or ask about: diabetes, heart disease, kidney disease, symptoms, or bed availability.";
    }
  }

  state.chatHistory.push({role:'bot',msg:reply});
  renderChatbot(document.getElementById('pane-chatbot'));
}

function clearChat(){
  state.chatHistory = [{role:'bot',msg:"Hello! 👋 I'm MedBot — your AI medical assistant."}];
  renderChatbot(document.getElementById('pane-chatbot'));
}

