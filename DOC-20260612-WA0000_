  const beds = getBeds();
  if(beds[bedType].avail<=0){ toast(`No beds in ${bedType}!`,'error'); return; }
  const p = {
    id: newId('P',state.patients),
    name, age: document.getElementById('np_age').value,
    gender: document.getElementById('np_gen').value,
    bloodGroup: document.getElementById('np_bg').value,
    phone: document.getElementById('np_ph').value,
    diagnosis: document.getElementById('np_diag').value,
    bedType, status:'Admitted',
    doctor: document.getElementById('np_doc').value,
    risk: document.getElementById('np_risk').value,
    admitted: now(),
  };
  state.patients.push(p);
  save();
  toast(`✅ Patient admitted — ID: ${p.id}`, 'success');
