<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>MediAI Hospital System</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F6FBF8;--card:#FFFFFF;--input:#EFF8F2;--accent:#1B7F4C;--accent2:#54B488;
  --danger:#D6473E;--warn:#D99A2B;--text:#16261E;--muted:#7C9286;--border:#DFEEE6;
  --r:12px;--sidebar:264px;--font-display:'Poppins',sans-serif;--font-body:'Inter','Segoe UI',sans-serif;--font-mono:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);min-height:100vh;line-height:1.5}
a{color:var(--accent);text-decoration:none}
@media (prefers-reduced-motion:reduce){
  *{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important;scroll-behavior:auto!important}
}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px;border-radius:6px}

/* ── Layout ── */
#app{display:flex;min-height:100vh}
#sidebar{width:var(--sidebar);background:var(--card);border-right:1px solid var(--border);
  padding:1.2rem 1rem;display:flex;flex-direction:column;gap:.8rem;position:fixed;
  top:0;left:0;height:100vh;overflow-y:auto;z-index:100;transition:transform .3s}
#main{margin-left:var(--sidebar);flex:1;padding:1.5rem 2rem;max-width:1400px}
@media(max-width:768px){
  #sidebar{transform:translateX(-100%)}
  #sidebar.open{transform:translateX(0)}
  #main{margin-left:0;padding:1rem}
}

/* ── Login ── */
#login-wrap{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1rem;
  background:radial-gradient(circle at 30% 20%,#E4F7EC 0%,#F6FBF8 55%)}
.login-box{background:var(--card);border:1px solid var(--border);border-radius:18px;
  padding:2.5rem 2rem;width:100%;max-width:400px;text-align:center;box-shadow:0 12px 36px rgba(27,127,76,.1)}
.login-box h2{font-family:var(--font-display);font-size:1.55rem;font-weight:700;margin:.5rem 0 .2rem;letter-spacing:-.01em}
.login-box p{color:var(--muted);font-size:.85rem;margin-bottom:1.5rem}

/* ── Inputs ── */
input,select,textarea{
  width:100%;background:var(--input);color:var(--text);border:1.5px solid var(--border);
  border-radius:8px;padding:.55rem .9rem;font-size:.9rem;outline:none;font-family:inherit;
  transition:border-color .15s,box-shadow .15s
}
input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(27,127,76,.12)}
input::placeholder,textarea::placeholder{color:var(--muted)}
label{display:block;font-size:.8rem;color:var(--muted);margin-bottom:.3rem;font-weight:500}
.field{margin-bottom:1rem}

/* ── Buttons ── */
.btn{
  background:linear-gradient(135deg,var(--accent),#3FBE7A);color:#fff;border:none;
  border-radius:8px;padding:.6rem 1.4rem;font-size:.88rem;font-weight:600;font-family:inherit;
  cursor:pointer;transition:opacity .15s,transform .1s,box-shadow .15s;width:100%
}
.btn:hover{opacity:.92;transform:translateY(-1px);box-shadow:0 4px 12px rgba(27,127,76,.25)}
.btn:active{transform:translateY(0)}
.btn:disabled{opacity:.55;cursor:not-allowed;transform:none;box-shadow:none}
.btn-sm{padding:.4rem .9rem;font-size:.8rem;width:auto}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--text)}
.btn-outline:hover{background:var(--input);box-shadow:none;border-color:var(--accent2)}
.btn-danger{background:var(--danger)}
.btn-success{background:var(--accent2)}

/* ── Cards & sections ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:1.2rem 1.4rem;margin-bottom:1rem;box-shadow:0 1px 4px rgba(27,127,76,.05)}
.hdr{background:linear-gradient(120deg,#E4F7EC 0%,#D3EFE0 60%,#C7ECD8 100%);border-radius:16px;
  padding:1.5rem 2rem;margin-bottom:1.2rem;border:1px solid var(--border);
  display:flex;align-items:center;gap:1.2rem;position:relative;overflow:hidden}
.hdr h1{font-family:var(--font-display);color:var(--text);font-size:1.7rem;font-weight:800;letter-spacing:-.02em}
.hdr p{color:var(--muted);font-size:.85rem;margin-top:.2rem;font-weight:500}
.hdr-icon{font-size:2.4rem;flex-shrink:0;filter:drop-shadow(0 2px 4px rgba(27,127,76,.2))}
.hdr-pulse{position:absolute;bottom:0;left:0;width:100%;height:34px;opacity:.35;pointer-events:none}
.badge{background:rgba(84,180,136,.18);color:#1B7F4C;border-radius:20px;
  padding:.3rem 1rem;font-size:.75rem;font-weight:700;margin-left:auto;display:flex;align-items:center;gap:.4rem;
  letter-spacing:.03em;white-space:nowrap}
.badge-dot{width:8px;height:8px;border-radius:50%;background:#1B7F4C;display:inline-block;animation:pulse-dot 1.8s ease-in-out infinite}
@keyframes pulse-dot{0%,100%{box-shadow:0 0 0 0 rgba(27,127,76,.5)}50%{box-shadow:0 0 0 5px rgba(27,127,76,0)}}

/* ── KPI cards ── */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.8rem;margin-bottom:1.2rem}
.kpi{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--accent2);border-radius:var(--r);padding:1rem 1.2rem;
  transition:transform .18s ease,box-shadow .18s ease;cursor:default}
.kpi:hover{transform:translateY(-3px);box-shadow:0 10px 24px rgba(27,127,76,.15)}
.kpi.kpi-danger{border-left-color:var(--danger)}
.kpi.kpi-warn{border-left-color:var(--warn)}
.kpi-label{color:var(--muted);font-size:.74rem;margin-bottom:.35rem;text-transform:uppercase;letter-spacing:.06em;font-weight:600}
.kpi-val{font-family:var(--font-display);font-size:1.9rem;font-weight:700;letter-spacing:-.02em}

/* ── Tabs ── */
.tabs{display:flex;flex-wrap:wrap;gap:.25rem;margin-bottom:1.2rem;border-bottom:1.5px solid var(--border);padding-bottom:0}
.tab{background:transparent;border:none;color:var(--muted);padding:.6rem 1rem;border-radius:8px 8px 0 0;
  font-size:.85rem;font-weight:600;cursor:pointer;transition:color .15s,background .15s;white-space:nowrap;
  border-bottom:2.5px solid transparent;margin-bottom:-1.5px}
.tab:hover{color:var(--text);background:var(--input)}
.tab.active{background:transparent;color:var(--accent);border-bottom-color:var(--accent)}
.pane{display:none}.pane.active{display:block;animation:fade-in .25s ease}
@keyframes fade-in{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

/* ── Sidebar nav ── */
.nav-btn{width:100%;text-align:left;background:transparent;border:none;border-left:3px solid transparent;color:var(--muted);
  padding:.6rem .8rem;border-radius:8px;font-size:.85rem;font-weight:500;cursor:pointer;transition:all .15s;
  display:flex;align-items:center;gap:.6rem}
.nav-btn:hover{background:var(--input);color:var(--text)}
.nav-btn.active{background:rgba(84,180,136,.14);color:var(--accent);border-left-color:var(--accent);font-weight:600}
.nav-sep{border:none;border-top:1px solid var(--border);margin:.4rem 0}
.stat-mini{display:grid;grid-template-columns:1fr 1fr;gap:.4rem;margin:.6rem 0}
.stat-mini-box{background:var(--input);border-radius:8px;padding:.5rem .6rem;text-align:center;transition:transform .15s}
.stat-mini-box:hover{transform:translateY(-1px)}
.stat-mini-box .v{font-family:var(--font-display);font-size:1.15rem;font-weight:700}
.stat-mini-box .l{font-size:.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:.04em}

/* ── Table ── */
.tbl{width:100%;border-collapse:collapse;font-size:.83rem}
.tbl th{background:var(--input);color:var(--accent);text-align:left;padding:.6rem .8rem;font-size:.78rem;letter-spacing:.5px}
.tbl td{padding:.6rem .8rem;border-bottom:1px solid var(--border)}
.tbl tr:hover td{background:rgba(46,158,91,.06)}
.tbl-wrap{overflow-x:auto;border-radius:var(--r);border:1px solid var(--border)}

/* ── Alerts ── */
.alert-high{background:#FDEAEA;border:1px solid var(--danger);border-radius:var(--r);padding:.8rem 1.1rem;margin:.4rem 0;font-size:.85rem;color:#7A2E2E}
.alert-medium{background:#FCF2E0;border:1px solid var(--warn);border-radius:var(--r);padding:.8rem 1.1rem;margin:.4rem 0;font-size:.85rem;color:#7A5A1E}
.alert-low{background:#E6F7ED;border:1px solid var(--accent2);border-radius:var(--r);padding:.8rem 1.1rem;margin:.4rem 0;font-size:.85rem;color:#1F5C3C}
.alert-info{background:rgba(46,158,91,.08);border:1px solid var(--accent);border-radius:var(--r);padding:.8rem 1.1rem;margin:.4rem 0;font-size:.85rem;color:#1F5C3C}

/* ── Chat ── */
.chat-box{height:340px;overflow-y:auto;background:var(--input);border-radius:var(--r);padding:1rem;margin-bottom:.8rem;display:flex;flex-direction:column;gap:.6rem;scroll-behavior:smooth}
.chat-user{background:rgba(27,127,76,.12);color:var(--text);border-radius:14px 14px 3px 14px;padding:.55rem .95rem;align-self:flex-end;max-width:80%;font-size:.85rem;animation:fade-in .2s ease}
.chat-bot{background:var(--card);border:1px solid var(--border);border-radius:14px 14px 14px 3px;padding:.55rem .95rem;align-self:flex-start;max-width:80%;font-size:.85rem;animation:fade-in .2s ease;box-shadow:0 1px 3px rgba(27,127,76,.05)}

/* ── Grid util ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
@media(max-width:640px){.g2,.g3{grid-template-columns:1fr}}

/* ── Misc ── */
.chip{display:inline-block;padding:.2rem .6rem;border-radius:20px;font-size:.72rem;font-weight:600}
.chip-high{background:#FDEAEA;color:var(--danger)}
.chip-medium{background:#FCF2E0;color:var(--warn)}
.chip-low{background:#E6F7ED;color:#1F8A53}
.chip-admitted{background:rgba(46,158,91,.12);color:var(--accent)}
.chip-discharged{background:rgba(95,191,143,.18);color:#1F8A53}
.text-muted{color:var(--muted)}
.text-accent{color:var(--accent)}
.text-success{color:var(--accent2)}
.text-danger{color:var(--danger)}
.mt-1{margin-top:1rem}.mb-1{margin-bottom:1rem}.mb-05{margin-bottom:.5rem}
h3{font-family:var(--font-display);font-size:1.02rem;font-weight:600;margin-bottom:.8rem;letter-spacing:-.01em}
h2{font-family:var(--font-display);font-size:1.35rem;font-weight:700;margin-bottom:1rem;letter-spacing:-.015em}
hr{border:none;border-top:1px solid var(--border);margin:1.2rem 0}
.spinner{display:inline-block;width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--card);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:var(--r);padding:.8rem 1.2rem;z-index:9999;font-size:.85rem;font-weight:500;opacity:0;transform:translateY(10px);transition:all .3s;box-shadow:0 8px 24px rgba(27,127,76,.15)}
.toast.show{opacity:1;transform:translateY(0)}
#mob-toggle{display:none;position:fixed;top:1rem;left:1rem;z-index:200;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:.4rem .7rem;cursor:pointer;color:var(--text);font-size:1.1rem}
@media(max-width:768px){#mob-toggle{display:block}}
</style>
</head>
<body>

<!-- Toast -->
<div id="toast" class="toast"></div>

<!-- Mobile toggle -->
<button id="mob-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>

<!-- LOGIN -->
<div id="login-wrap">
<div class="login-box">
  <div style="font-size:3rem">🏥</div>
  <h2>MediAI Login</h2>
  <p>Secure access to Hospital Management System</p>
  <div class="field"><label>👤 Username</label><input id="uname" placeholder="arjun / admin / nurse" autocomplete="username"/></div>
  <div class="field"><label>🔒 Password</label><input id="upwd" type="password" placeholder="••••••••" autocomplete="current-password"/></div>
  <div class="field" style="text-align:left"><small class="text-muted">Login: arjun:670798 &nbsp;|&nbsp; admin:admin1234 &nbsp;|&nbsp; nurse:nurse123</small></div>
  <div id="login-err" style="color:var(--danger);font-size:.82rem;margin-bottom:.6rem;display:none">❌ Invalid credentials</div>
  <button class="btn" onclick="doLogin()">🔐 Sign In</button>
</div>
</div>

<!-- APP SHELL (hidden until login) -->
<div id="app" style="display:none">

<!-- Sidebar -->
<div id="sidebar">
  <div class="card" style="text-align:center;padding:1rem">
    <div id="sb-icon" style="font-size:2rem">👩‍💼</div>
    <div id="sb-name" style="font-weight:700;margin:.3rem 0"></div>
    <div id="sb-role" style="color:var(--accent2);font-size:.72rem;text-transform:uppercase;letter-spacing:1px"></div>
  </div>
  <div>
    <div class="text-muted" style="font-size:.72rem;padding:0 .4rem;margin-bottom:.4rem">📊 QUICK STATS</div>
    <div class="stat-mini" id="sb-stats"></div>
  </div>
  <hr/>
  <nav id="sb-nav"></nav>
  <hr/>
  <div class="text-muted" style="font-size:.78rem;padding:.2rem .4rem" id="sb-time"></div>
  <button class="btn btn-outline" style="margin-top:.4rem" onclick="doLogout()">🚪 Logout</button>
</div>

<!-- Main content -->
<div id="main">
  <!-- Header banner -->
  <div class="hdr">
    <span class="hdr-icon">🏥</span>
    <div>
      <h1>MediAI Hospital System</h1>
      <p>AI-powered disease prediction &amp; intelligent bed management</p>
    </div>
    <div class="badge"><span class="badge-dot"></span> System online</div>
    <svg class="hdr-pulse" viewBox="0 0 600 40" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,20 L60,20 L75,8 L90,32 L105,20 L160,20 L175,12 L190,28 L205,20 L600,20"
        fill="none" stroke="#1B7F4C" stroke-width="2"/>
    </svg>
  </div>

  <!-- Tabs -->
  <div class="tabs" id="tabs"></div>

  <!-- Panes -->
  <div id="pane-overview" class="pane active"></div>
  <div id="pane-prediction" class="pane"></div>
  <div id="pane-patients" class="pane"></div>
  <div id="pane-beds" class="pane"></div>
  <div id="pane-analytics" class="pane"></div>
  <div id="pane-history" class="pane"></div>
  <div id="pane-chatbot" class="pane"></div>
  <div id="pane-database" class="pane"></div>
</div>
</div>

<script>
// ═══════════════════════════════════════
// STATE
// ═══════════════════════════════════════
const USERS = {
  arjun: {pw:'670798', role:'doctor', name:'Dr. Arjun'},
  admin: {pw:'admin1234', role:'admin', name:'Dr. Admin'},
  nurse: {pw:'nurse123', role:'nurse', name:'Nurse Priya'},
};

let state = {
  user: null,
  patients: JSON.parse(localStorage.getItem('mediai_patients')||'[]'),
  predictions: JSON.parse(localStorage.getItem('mediai_predictions')||'[]'),
  chatHistory: [{role:'bot',msg:"Hello! 👋 I'm MedBot — your AI medical assistant. Ask me about diseases, symptoms, or bed status."}],
  activePane: 'overview',
  charts: {},
};

const BED_CAP = {ICU:20, Emergency:30, General:100};

// ═══════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════
function save(){
  localStorage.setItem('mediai_patients', JSON.stringify(state.patients));
  localStorage.setItem('mediai_predictions', JSON.stringify(state.predictions));
}

function toast(msg, type='info'){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.borderColor = type==='success'?'var(--accent2)':type==='error'?'var(--danger)':'var(--accent)';
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 3000);
}

function getStats(){
  const p = state.patients;
  return {
    total: p.length,
    admitted: p.filter(x=>x.status==='Admitted').length,
    discharged: p.filter(x=>x.status==='Discharged').length,
    critical: p.filter(x=>x.status==='Critical').length,
    highRisk: p.filter(x=>x.risk==='High').length,
  };
}

function getBeds(){
  const occupied = {ICU:0, Emergency:0, General:0};
  state.patients.filter(p=>['Admitted','Critical','Stable'].includes(p.status))
    .forEach(p=>{ if(occupied[p.bedType]!==undefined) occupied[p.bedType]++; });
  const r = {};
  for(const [k,cap] of Object.entries(BED_CAP)){
    const occ = Math.min(occupied[k], cap);
    r[k] = {cap, occ, avail:cap-occ, pct:Math.round(occ/cap*100)};
  }
  return r;
}

function newId(prefix,arr){ return prefix+(arr.length+1).toString().padStart(4,'0'); }
function now(){ return new Date().toLocaleString('en-IN'); }

// ═══════════════════════════════════════
// AUTH
// ═══════════════════════════════════════
function doLogin(){
  const u = document.getElementById('uname').value.trim().toLowerCase();
  const p = document.getElementById('upwd').value;
  const user = USERS[u];
  if(user && user.pw === p){
    state.user = {...user, username:u};
    document.getElementById('login-wrap').style.display='none';
    document.getElementById('app').style.display='flex';
    document.getElementById('login-err').style.display='none';
    initApp();
  } else {
    document.getElementById('login-err').style.display='block';
  }
}

document.getElementById('upwd').addEventListener('keydown',e=>{ if(e.key==='Enter') doLogin(); });

function doLogout(){
  state.user=null;
  document.getElementById('login-wrap').style.display='flex';
  document.getElementById('app').style.display='none';
  document.getElementById('uname').value='';
  document.getElementById('upwd').value='';
}

// ═══════════════════════════════════════
// APP INIT
// ═══════════════════════════════════════
function initApp(){
  // Sidebar user info
  const icons = {admin:'👩‍💼', doctor:'🧑‍⚕️', nurse:'👩‍⚕️'};
  document.getElementById('sb-icon').textContent = icons[state.user.role]||'👤';
  document.getElementById('sb-name').textContent = state.user.name;
  document.getElementById('sb-role').textContent = state.user.role;

  // Time ticker
  const tick=()=>{ document.getElementById('sb-time').textContent='🕐 '+new Date().toLocaleTimeString('en-IN'); };
  tick(); setInterval(tick, 1000);

  // Tabs
  const tabDefs=[
    {id:'overview',label:'🏠 Overview'},
    {id:'prediction',label:'🔬 Prediction'},
    {id:'patients',label:'👥 Patients'},
    {id:'beds',label:'🛏️ Beds'},
    {id:'analytics',label:'📈 Analytics'},
    {id:'history',label:'📋 History'},
    {id:'chatbot',label:'🤖 MedBot'},
    {id:'database',label:'🗄️ Database'},
  ];
  const tabsEl = document.getElementById('tabs');
  tabsEl.innerHTML = tabDefs.map(t=>`<button class="tab${t.id===state.activePane?' active':''}" onclick="switchPane('${t.id}')">${t.label}</button>`).join('');

  // Sidebar nav
  document.getElementById('sb-nav').innerHTML = tabDefs.map(t=>`<button class="nav-btn${t.id===state.activePane?' active':''}" onclick="switchPane('${t.id}')">${t.label}</button>`).join('');

  refreshAll();
}

function switchPane(id){
  state.activePane = id;
  document.querySelectorAll('.pane').forEach(p=>p.classList.remove('active'));
  document.getElementById('pane-'+id).classList.add('active');
  document.querySelectorAll('.tab').forEach(t=>{
    t.classList.toggle('active', t.textContent.includes(id.charAt(0).toUpperCase()+id.slice(1)));
  });
  document.querySelectorAll('.nav-btn').forEach(b=>{
    b.classList.toggle('active', b.textContent.toLowerCase().includes(id));
  });
  // Close mobile sidebar
  document.getElementById('sidebar').classList.remove('open');
  renderPane(id);
}

function refreshAll(){
  updateSidebarStats();
  renderPane(state.activePane);
}

function updateSidebarStats(){
  const s = getStats();
  document.getElementById('sb-stats').innerHTML=`
    <div class="stat-mini-box"><div class="v">${s.total}</div><div class="l">Total</div></div>
    <div class="stat-mini-box"><div class="v">${s.admitted}</div><div class="l">Admitted</div></div>
    <div class="stat-mini-box"><div class="v" style="color:var(--danger)">${s.critical}</div><div class="l">Critical</div></div>
    <div class="stat-mini-box"><div class="v" style="color:var(--warn)">${s.highRisk}</div><div class="l">High Risk</div></div>
  `;
}

function renderPane(id){
  const el = document.getElementById('pane-'+id);
  switch(id){
    case 'overview':   renderOverview(el); break;
    case 'prediction': renderPrediction(el); break;
    case 'patients':   renderPatients(el); break;
    case 'beds':       renderBeds(el); break;
    case 'analytics':  renderAnalytics(el); break;
    case 'history':    renderHistory(el); break;
    case 'chatbot':    renderChatbot(el); break;
    case 'database':   renderDatabase(el); break;
  }
}

// ═══════════════════════════════════════
// PANE: OVERVIEW
// ═══════════════════════════════════════
function renderOverview(el){
  const s = getStats();
  const beds = getBeds();
  const diagCount = {};
  state.patients.forEach(p=>{ if(p.diagnosis) diagCount[p.diagnosis]=(diagCount[p.diagnosis]||0)+1; });
  const riskCount = {High:0,Medium:0,Low:0};
  state.patients.forEach(p=>{ if(p.risk) riskCount[p.risk]=(riskCount[p.risk]||0)+1; });

  el.innerHTML=`
