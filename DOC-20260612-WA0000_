async function runPrediction(disease){
  const btn = document.getElementById('pred-btn');
  btn.innerHTML='<span class="spinner"></span> Analysing…';
  btn.disabled=true;

  // Collect fields
  const fields = DISEASE_FIELDS[disease];
  const vals = {};
  fields.forEach(f=>{ vals[f.k]=parseFloat(document.getElementById('pf_'+f.k).value)||0; });

  // Build prompt for Anthropic API
  const prompt = `You are a medical AI assistant. Analyse these patient parameters for ${disease} risk prediction.

Parameters: ${JSON.stringify(vals)}

Based on clinical knowledge of ${disease}:
1. Assign a risk probability (0.0 to 1.0) based on clinical thresholds
2. Give prediction: Positive or Negative
3. List 3-4 specific medical recommendations

Respond ONLY in this JSON format (no extra text):
{"probability":0.73,"prediction":"Positive","risk":"High","recommendations":["rec1","rec2","rec3"]}

Rules:
- Diabetes: glucose>140, BMI>30, age>40 increase risk
- Heart Disease: chol>240, trestbps>140, age>50+male increase risk  
- Kidney Disease: sc>2.5, bu>100, htn=1 increase risk
- risk: "High" if prob>0.65, "Medium" if 0.35-0.65, "Low" if <0.35`;

  let label, prob, risk, recs;
  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:400,
        messages:[{role:'user',content:prompt}]
      })
    });
    const data = await resp.json();
    const text = data.content.map(c=>c.text||'').join('');
    const clean = text.replace(/```json|```/g,'').trim();
    const parsed = JSON.parse(clean);
    label = parsed.prediction;
    prob = Math.max(0, Math.min(1, parsed.probability));
    risk = parsed.risk;
    recs = parsed.recommendations;
  } catch(e) {
    // Fallback: rule-based scoring
    const r = ruleBasedScore(disease, vals);
    label=r.label; prob=r.prob; risk=r.risk; recs=r.recs;
  }

  // Save prediction
  const pred = {
    id: newId('PRED',state.predictions),
    patientId: 'MANUAL',
    disease, label, prob: prob.toFixed(4),
    timestamp: now(),
  };
  state.predictions.push(pred);
  save();

  // Show result
  const color = label==='Positive'?'var(--danger)':'var(--accent2)';
  const icon  = label==='Positive'?'🔴':'🟢';
  const alertClass = `alert-${risk.toLowerCase()}`;
  document.getElementById('pred-result').innerHTML=`
    <div class="g2 mt-1">
      <div class="card" style="text-align:center;border-color:${color}">
        <div style="font-size:3rem">${icon}</div>
        <div style="font-size:1.5rem;font-weight:800;color:${color}">${label}</div>
        <div class="text-muted" style="margin:.3rem 0">${disease} Prediction</div>
        <div>Confidence: <strong style="color:${color}">${(prob*100).toFixed(1)}%</strong></div>
        <div style="margin-top:.5rem">
          <div style="background:var(--input);border-radius:6px;height:12px;overflow:hidden">
            <div style="height:100%;width:${(prob*100).toFixed(1)}%;background:${color};border-radius:6px"></div>
          </div>
        </div>
        <div class="text-muted mt-1" style="font-size:.78rem">AI-powered clinical analysis</div>
      </div>
      <div class="card">
        <h3>💊 AI Recommendations</h3>
        ${(recs||[]).map(r=>`<div class="${alertClass}" style="margin:.35rem 0">${r}</div>`).join('')}
      </div>
    </div>
  `;

  btn.innerHTML='🚀 Run AI Prediction';
  btn.disabled=false;
  updateSidebarStats();
}

// Rule-based fallback
function ruleBasedScore(disease, vals){
  let score = 0;
  if(disease==='Diabetes'){
    if(vals.Glucose>140) score+=.3;
    if(vals.BMI>30) score+=.2;
    if(vals.Age>40) score+=.1;
    if(vals.Insulin>200) score+=.1;
    if(vals.DiabetesPedigreeFunction>1) score+=.1;
    if(vals.Pregnancies>5) score+=.05;
  } else if(disease==='Heart Disease'){
    if(vals.chol>240) score+=.25;
    if(vals.trestbps>140) score+=.2;
    if(vals.age>50&&vals.sex===1) score+=.2;
    if(vals.cp>1) score+=.15;
    if(vals.exang===1) score+=.1;
    if(vals.ca>0) score+=.1;
  } else {
    if(vals.sc>19) score+=.3;
    if(vals.bu>57) score+=.2;
    if(vals.htn===1) score+=.2;
    if(vals.dm===1) score+=.15;
    if(vals.al>0) score+=.1;
  }
  const prob = Math.min(0.95, score);
  const risk = prob>0.65?'High':prob>0.35?'Medium':'Low';
  const recs = getRecs(disease, prob>0.5?'Positive':'Negative', risk, vals);
  return {label:prob>0.5?'Positive':'Negative', prob, risk, recs};
}

function getRecs(disease, label, risk, vals){
  if(label==='Negative') return ['✅ No disease detected. Maintain a healthy lifestyle.','📅 Schedule annual check-up.'];
  const r=[];
  if(risk==='High') r.push('🚨 HIGH RISK — Immediate medical attention required!');
  if(disease==='Diabetes'){
    if((vals.Glucose||0)>140) r.push('🩸 High glucose — consult endocrinologist.');
    if((vals.BMI||0)>30) r.push('⚖️ Elevated BMI — diet & exercise plan recommended.');
    r.push('💊 HbA1c test recommended within 2 weeks.');
  } else if(disease==='Heart Disease'){
    r.push('❤️ Cardiology consultation strongly recommended.');
    if((vals.chol||0)>240) r.push('📉 High cholesterol — lipid panel & statin review advised.');
    r.push('🩺 ECG and stress test advised.');
  } else {
    r.push('🫘 Nephrology referral recommended.');
    r.push('💧 Increase water intake to ≥ 2 L/day.');
    r.push('🧂 Reduce sodium intake.');
  }
  return r;
}

